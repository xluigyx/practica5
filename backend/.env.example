# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=*

# ── Cassandra / Kafka ────────────────────────────────────────────────────────
CASSANDRA_HOSTS=localhost
CASSANDRA_KEYSPACE=semapa
KAFKA_BROKERS=localhost:29092

# ── WhatsApp — Evolution API (recomendado) ───────────────────────────────────
WHATSAPP_PROVIDER=evolution
# Número del bot (solo dígitos, con código país) — usado en wa.me al redirigir desde el tótem
# Número WhatsApp del bot (Evolution, NO Business API) — +591 62658425
WHATSAPP_BOT_PHONE=59162658425
WHATSAPP_BUSINESS_PHONE=59162658425

EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tu_api_key_de_evolution
EVOLUTION_INSTANCE=semapa

# Webhook Evolution → debe apuntar a tu API:
# http://TU-SERVIDOR:4000/api/whatsapp/evolution/webhook
# Eventos: MESSAGES_UPSERT

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

